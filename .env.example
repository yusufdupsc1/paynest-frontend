# PayNest Frontend Environment Reference
# Copy this file to .env.local for local development.
# Do not commit real secrets or environment-specific overrides.

# Backend API origin. Omit the trailing slash.
# Local development: http://localhost:3000
# Production: https://<service>.onrender.com
NEXT_PUBLIC_API_URL=https://your-render-service.onrender.com

# Public variables are bundled into browser assets. Never place secrets in
# variables prefixed with NEXT_PUBLIC_.
